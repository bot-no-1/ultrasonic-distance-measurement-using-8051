#include <reg51.h>
sbit TRG = P2^0;
sbit ECH = P2^1;
sbit BUZ = P2^2; 
sbit RS  = P1^0;
sbit RW  = P1^1;
sbit EN  = P1^2;
void delay(unsigned int ms) {
    unsigned int i, j;
    for(i=0; i<ms; i++)
        for(j=0; j<1275; j++);
}
void lcd_cmd(unsigned char cmd) {
    P3 = cmd;
    RS = 0; RW = 0; EN = 1;
    delay(1);
    EN = 0;
}
void lcd_data(unsigned char dat) {
    P3 = dat;
    RS = 1; RW = 0; EN = 1;
    delay(1);
    EN = 0;
}
void main() {
    unsigned int count, distance, total_distance;
    unsigned char i; 
    TMOD = 0x01; 
    BUZ = 0;        
    lcd_cmd(0x38); lcd_cmd(0x0C); lcd_cmd(0x01);
    while(1) {
        total_distance = 0;
        for(i = 0; i < 5; i++) {
            TRG = 0; delay(1);
            TRG = 1; delay(1);
            TRG = 0;
            while(ECH == 0); 
            TR0 = 1;         
            while(ECH == 1); 
            TR0 = 0;     
            count = (TH0 << 8) | TL0; 
            total_distance += (count + 27) / 54; 
            TH0 = 0; TL0 = 0; 
            delay(10); 
        }
        distance = total_distance / 5;
        if(distance < 15 && distance > 0) { 
            BUZ = 1; 
        } else {
            BUZ = 0;
        }
        lcd_cmd(0x80); 
        lcd_data('D');lcd_data('i');lcd_data('s');lcd_data('t');lcd_data('a');lcd_data('n');lcd_data('c');lcd_data('e');lcd_data('=');
        lcd_data((distance / 100) + '0');
        lcd_data(((distance / 10) % 10) + '0');
        lcd_data((distance % 10) + '0');        
        lcd_data(' '); lcd_data('c'); lcd_data('m');      
        delay(250);
    }
}
